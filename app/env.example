# Connecting Traveller — Ops Console
# Copy this file to .env.local and fill in real values. .env.local is gitignored.

# ──────────────────────────────────────────────────────────────────────────
# Anthropic (Claude Sonnet 4.6 — intake agent)
# Get from: https://console.anthropic.com/
# ──────────────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=

# Default model. Override if you want to test Haiku for cheaper extraction.
ANTHROPIC_MODEL=claude-sonnet-4-6

# ──────────────────────────────────────────────────────────────────────────
# AISensy (WhatsApp BSP — inbound webhook + outbound send + broadcast)
# Get from: AISensy dashboard → API settings
# Pending Phase 1b.0 audit: confirm webhook + outbound + broadcast support
# ──────────────────────────────────────────────────────────────────────────
AISENSY_API_KEY=
AISENSY_WEBHOOK_SECRET=

# Phone number that receives hot-lead notifications. E.164 format with country code.
# Example: 919876543210
AISENSY_AGENT_PHONE=

# Name of the Meta-approved template for the hot-lead notification message.
# Must be submitted and approved in AISensy / Meta Business Manager before go-live.
AISENSY_TEMPLATE_HOT_LEAD=hot_lead_notification_v1
AISENSY_TEMPLATE_GREETING=intake_greeting_v1

# ──────────────────────────────────────────────────────────────────────────
# Airtable (lead database for v1)
# Get from: https://airtable.com/account
# Migration trigger: 5k+ leads, $50+/mo cost, or repeated rate-limit errors → Supabase
# ──────────────────────────────────────────────────────────────────────────
AIRTABLE_API_KEY=
AIRTABLE_BASE_ID=
AIRTABLE_LEADS_TABLE=Leads
AIRTABLE_TRIPS_TABLE=Trips

# ──────────────────────────────────────────────────────────────────────────
# Langfuse Cloud (LLM observability, 50k observations/month free tier)
# Get from: https://cloud.langfuse.com → settings → API keys
# ──────────────────────────────────────────────────────────────────────────
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com
